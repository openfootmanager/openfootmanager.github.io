---
import BaseLayout from "./BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { type Lang, defaultLang } from "../i18n/ui";
import { useTranslations, getLocalePath, getDateLocale } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  image?: string;
  lang?: Lang;
}

const lang = Astro.props.lang ?? defaultLang;
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = "Openfoot Manager Team",
  tags = [],
  image,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString(dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString(dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={`${title} — Openfoot Manager Blog`}
  description={description}
  image={image}
  lang={lang}
>
  <article class="pt-32 pb-24">
    <div class="container-narrow">
      <!-- Back link -->
      <a
        href={getLocalePath(lang, "/blog")}
        class="inline-flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors mb-8"
      >
        <Icon name="lucide:chevron-left" class="h-4 w-4" />
        {t("blog.back")}
      </a>

      <!-- Header -->
      <header class="mb-12">
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {tags.map((tag) => (
                <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )
        }

        <h1
          class="font-heading text-4xl md:text-5xl font-bold uppercase text-slate-900 dark:text-white mb-4"
        >
          {title}
        </h1>

        <div
          class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400"
        >
          <span>{t("blog.by")} {author}</span>
          <span>·</span>
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {
            formattedUpdatedDate && (
              <>
                <span>·</span>
                <span>
                  {t("blog.updated")} {formattedUpdatedDate}
                </span>
              </>
            )
          }
        </div>
      </header>

      {
        image && (
          <img
            src={image}
            alt={title}
            width="1200"
            height="630"
            fetchpriority="high"
            class="w-full h-64 md:h-96 object-cover rounded-2xl mb-12"
          />
        )
      }

      <!-- Content -->
      <div class="prose-blog">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
