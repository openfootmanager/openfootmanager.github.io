---
import { Icon } from 'astro-icon/components';
import { type Lang, defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? defaultLang;
const t = useTranslations(lang);

const features = [
  { icon: 'lucide:code', title: t('features.opensource.title'), description: t('features.opensource.desc') },
  { icon: 'lucide:globe', title: t('features.matchengine.title'), description: t('features.matchengine.desc') },
  { icon: 'lucide:wifi-off', title: t('features.offline.title'), description: t('features.offline.desc') },
  { icon: 'lucide:database', title: t('features.moddable.title'), description: t('features.moddable.desc') },
  { icon: 'lucide:monitor', title: t('features.crossplatform.title'), description: t('features.crossplatform.desc') },
  { icon: 'lucide:zap', title: t('features.fast.title'), description: t('features.fast.desc') },
];
---

<section id="features" class="py-24 bg-white dark:bg-slate-950">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 text-xs font-heading font-bold uppercase tracking-widest text-emerald-600 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/30 rounded-full mb-4">
        {t('features.badge')}
      </span>
      <h2 class="font-heading text-4xl md:text-5xl font-bold uppercase text-slate-900 dark:text-white">
        {t('features.heading.pre')} <span class="text-emerald-500">{t('features.heading.highlight')}</span>?
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        {t('features.subheading')}
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {features.map((feature) => (
        <div class="group relative p-8 rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 hover:border-emerald-500/50 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 dark:bg-emerald-500/10 flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
            <Icon name={feature.icon} class="w-6 h-6 text-emerald-500" />
          </div>
          <h3 class="font-heading text-xl font-bold text-slate-900 dark:text-white uppercase mb-3">
            {feature.title}
          </h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
