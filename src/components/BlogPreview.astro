---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { type Lang, defaultLang } from '../i18n/ui';
import { useTranslations, getLocalePath, getDateLocale, getBaseSlug } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? defaultLang;
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && (post.data.lang ?? 'en') === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

{posts.length > 0 && (
  <section class="py-24 bg-white dark:bg-slate-950">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block px-4 py-1.5 text-xs font-heading font-bold uppercase tracking-widest text-emerald-600 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/30 rounded-full mb-4">
          {t('blog.badge')}
        </span>
        <h2 class="font-heading text-4xl md:text-5xl font-bold uppercase text-slate-900 dark:text-white">
          {t('blog.heading.pre')} <span class="text-emerald-500">{t('blog.heading.highlight')}</span>
        </h2>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          {t('blog.subheading')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {posts.map((post) => (
          <a
            href={getLocalePath(lang, `/blog/${getBaseSlug(post.slug)}`)}
            class="group block rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 overflow-hidden hover:border-emerald-500/50 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300"
          >
            {post.data.image && (
              <div class="overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="font-heading text-xl font-bold uppercase text-slate-900 dark:text-white group-hover:text-emerald-500 transition-colors mb-2">
                {post.data.title}
              </h3>
              <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">
                {post.data.description}
              </p>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-xs text-slate-500 dark:text-slate-500"
              >
                {post.data.pubDate.toLocaleDateString(dateLocale, {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href={getLocalePath(lang, '/blog')}
          class="inline-flex items-center gap-2 px-6 py-3 font-heading font-semibold uppercase tracking-wider text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 transition-colors"
        >
          {t('blog.viewall')}
          <Icon name="lucide:chevron-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>
)}
