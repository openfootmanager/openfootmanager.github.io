---
import ThemeToggle from "./ThemeToggle";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { Icon } from "astro-icon/components";
import { type Lang, defaultLang } from "../i18n/ui";
import { useTranslations, getLocalePath } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? defaultLang;
const t = useTranslations(lang);

const navLinks = [
  { href: getLocalePath(lang, "/features"), label: t("nav.features") },
  { href: getLocalePath(lang, "/blog"), label: t("nav.blog") },
  { href: getLocalePath(lang, "/about"), label: t("nav.about") },
];

const downloadLink = {
  href: getLocalePath(lang, "/download"),
  label: t("nav.download"),
};
---

<header
  id="main-header"
  class="fixed top-0 w-full z-50 transition-all duration-300"
>
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a
        href={getLocalePath(lang, "/")}
        class="flex items-center gap-3 group"
        aria-label="Openfoot Manager"
      >
        <img
          src="/openfootball.svg"
          alt="Openfoot Manager"
          width="36"
          height="36"
          class="h-9 w-9 transition-transform group-hover:scale-110"
        />
        <span
          class="font-heading font-bold text-xl uppercase tracking-wider text-white"
        >
          Openfoot <span class="text-emerald-600 dark:text-emerald-400"
            >Manager</span
          >
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="px-4 py-2 text-sm font-heading font-semibold uppercase tracking-wider text-slate-300 hover:text-white transition-colors rounded-lg hover:bg-white/10"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href={downloadLink.href}
          class="px-4 py-2 text-sm font-heading font-bold uppercase tracking-wider text-white bg-emerald-500 hover:bg-emerald-400 rounded-lg transition-all duration-200 shadow-md shadow-emerald-500/25 flex items-center gap-1.5"
        >
          <Icon name="lucide:download" class="w-4 h-4" />
          {downloadLink.label}
        </a>
        <a
          href="https://github.com/openfootmanager/openfootmanager"
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 text-sm font-heading font-semibold uppercase tracking-wider text-slate-300 hover:text-white transition-colors rounded-lg hover:bg-white/10 flex items-center gap-2"
        >
          <Icon name="lucide:github" class="w-5 h-5" />
          GitHub
        </a>
        <div class="ml-2 border-l border-white/20 pl-2 flex items-center gap-2">
          <LanguageSwitcher lang={lang} />
          <ThemeToggle client:load />
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-2 md:hidden">
        <LanguageSwitcher lang={lang} />
        <ThemeToggle client:load />
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg text-slate-300 hover:text-white hover:bg-white/10 transition-colors"
          aria-label="Toggle menu"
        >
          <Icon id="menu-icon-open" name="lucide:menu" class="w-6 h-6" />
          <Icon id="menu-icon-close" name="lucide:x" class="w-6 h-6 hidden" />
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-emerald-950/95 backdrop-blur-md border-t border-white/10"
  >
    <div class="container mx-auto px-4 py-4 space-y-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 text-sm font-heading font-semibold uppercase tracking-wider text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={downloadLink.href}
        class="flex items-center gap-2 px-4 py-3 text-sm font-heading font-bold uppercase tracking-wider text-white bg-emerald-500 hover:bg-emerald-400 rounded-lg transition-all duration-200"
      >
        <Icon name="lucide:download" class="w-4 h-4" />
        {downloadLink.label}
      </a>
      <a
        href="https://github.com/openfootmanager/openfootmanager"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-3 text-sm font-heading font-semibold uppercase tracking-wider text-slate-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors"
      >
        <Icon name="lucide:github" class="w-5 h-5" />
        GitHub
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("main-header");
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  // Scroll effect
  function updateHeader() {
    if (!header) return;
    if (window.scrollY > 50) {
      header.classList.add(
        "bg-emerald-950/95",
        "backdrop-blur-md",
        "shadow-lg",
      );
    } else {
      header.classList.remove(
        "bg-emerald-950/95",
        "backdrop-blur-md",
        "shadow-lg",
      );
    }
  }

  window.addEventListener("scroll", updateHeader);
  updateHeader();

  // Mobile menu toggle
  mobileBtn?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");

    if (!isOpen) {
      header?.classList.add("bg-emerald-950/95", "backdrop-blur-md");
    } else {
      updateHeader();
    }
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
