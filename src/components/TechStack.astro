---
import { Icon } from 'astro-icon/components';
import { type Lang, defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? defaultLang;
const t = useTranslations(lang);

const layers = [
  {
    icon: 'lucide:cog',
    title: t('tech.engine.title'),
    tech: 'Rust',
    description: t('tech.engine.desc'),
    color: 'from-orange-500 to-red-600',
    iconColor: 'text-orange-500',
  },
  {
    icon: 'lucide:palette',
    title: t('tech.ui.title'),
    tech: 'React + TypeScript',
    description: t('tech.ui.desc'),
    color: 'from-cyan-500 to-blue-600',
    iconColor: 'text-cyan-500',
  },
  {
    icon: 'lucide:monitor',
    title: t('tech.desktop.title'),
    tech: 'Tauri v2',
    description: t('tech.desktop.desc'),
    color: 'from-amber-500 to-yellow-600',
    iconColor: 'text-amber-500',
  },
];

const techBadges = [
  'Rust', 'Tauri v2', 'React 19', 'TypeScript', 'Vite 7',
  'Tailwind CSS', 'Zustand', 'SQLite', 'i18next', 'Lucide',
];
---

<section class="py-24 bg-slate-50 dark:bg-slate-900">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 text-xs font-heading font-bold uppercase tracking-widest text-amber-600 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/30 rounded-full mb-4">
        {t('tech.badge')}
      </span>
      <h2 class="font-heading text-4xl md:text-5xl font-bold uppercase text-slate-900 dark:text-white">
        {t('tech.heading.pre')} <span class="text-amber-500">{t('tech.heading.highlight')}</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        {t('tech.subheading')}
      </p>
    </div>

    <!-- Architecture cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto mb-16">
      {layers.map((layer) => (
        <div class="relative p-8 rounded-2xl bg-white dark:bg-slate-800 shadow-sm border border-slate-200 dark:border-slate-700 text-center">
          <div class="flex justify-center mb-4">
            <div class={`w-14 h-14 rounded-2xl bg-slate-100 dark:bg-slate-700 flex items-center justify-center ${layer.iconColor}`}>
              <Icon name={layer.icon} class="w-7 h-7" />
            </div>
          </div>
          <h3 class="font-heading text-lg font-bold uppercase text-slate-900 dark:text-white mb-1">
            {layer.title}
          </h3>
          <p class={`font-heading text-xl font-bold uppercase bg-gradient-to-r ${layer.color} bg-clip-text text-transparent mb-3`}>
            {layer.tech}
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            {layer.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Tech badges -->
    <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
      {techBadges.map((badge) => (
        <span class="px-4 py-2 text-sm font-heading font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-300 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-full">
          {badge}
        </span>
      ))}
    </div>
  </div>
</section>
