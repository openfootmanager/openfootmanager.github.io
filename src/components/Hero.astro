---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { type Lang, defaultLang } from "../i18n/ui";
import { useTranslations, getLocalePath } from "../i18n/utils";

import crowdImg from "../assets/crowd.jpg";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? defaultLang;
const t = useTranslations(lang);
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background image -->
  <div class="absolute inset-0">
    <Image
      src={crowdImg}
      alt=""
      widths={[640, 1024, 1920, crowdImg.width]}
      sizes="100vw"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-emerald-950/80 via-emerald-950/60 to-slate-950"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <img
      src="/openfootlogo.svg"
      alt="Openfoot Manager"
      width="762"
      height="223"
      fetchpriority="high"
      class="h-28 md:h-36 mx-auto w-auto mb-8 drop-shadow-2xl animate-fade-in"
    />

    <h1
      class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold text-white uppercase tracking-tight mb-6 animate-slide-up"
    >
      {t("hero.heading.line1")}<br />
      <span class="text-amber-400">{t("hero.heading.line2")}</span>
    </h1>

    <p
      class="text-lg md:text-xl text-emerald-100/70 mb-5 max-w-2xl mx-auto leading-relaxed animate-slide-up"
      style="animation-delay: 0.15s;"
    >
      {t("hero.subtitle2")}
    </p>

    <p
      class="text-lg md:text-xl text-emerald-100/70 mb-10 max-w-2xl mx-auto leading-relaxed animate-slide-up"
      style="animation-delay: 0.15s;"
    >
      {t("hero.subtitle3")}
    </p>

    <div
      class="flex flex-wrap justify-center gap-4 animate-slide-up"
      style="animation-delay: 0.3s;"
    >
      <a
        href={getLocalePath(lang, "/download")}
        class="inline-flex items-center gap-2 px-8 py-4 bg-emerald-500 hover:bg-emerald-400 text-white font-heading text-lg font-bold uppercase tracking-wider rounded-xl transition-all duration-200 shadow-lg shadow-emerald-500/25 hover:shadow-emerald-400/30 hover:-translate-y-0.5"
      >
        <Icon name="lucide:download" class="w-5 h-5" />
        {t("nav.download")}
      </a>
      <a
        href="https://github.com/openfootmanager/openfootmanager"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/25 hover:border-white/50 text-white font-heading text-lg font-bold uppercase tracking-wider rounded-xl transition-all duration-200 hover:-translate-y-0.5"
      >
        <Icon name="lucide:github" class="w-5 h-5" />
        {t("hero.cta.github")}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <Icon name="lucide:arrow-down" class="h-6 w-6 text-white/40" />
  </div>
</section>
