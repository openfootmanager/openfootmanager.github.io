---
import { Icon } from "astro-icon/components";
import { languages, defaultLang, type Lang } from "../i18n/ui";

interface Props {
  lang?: Lang;
}

const currentLang = Astro.props.lang ?? defaultLang;
const localePattern = Object.keys(languages)
  .filter((lang) => lang !== defaultLang)
  .map((lang) => lang.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"))
  .join("|");

// Get the current path without the lang prefix
const pathname = Astro.url.pathname;
const pathWithoutLang = localePattern
  ? pathname.replace(new RegExp(`^/(${localePattern})(/|$)`), "/")
  : pathname;

function getPathForLang(targetLang: Lang): string {
  if (targetLang === defaultLang) return pathWithoutLang || "/";
  return (
    `/${targetLang}${pathWithoutLang === "/" ? "" : pathWithoutLang}` ||
    `/${targetLang}`
  );
}

const langEntries = Object.entries(languages) as [Lang, string][];
---

<div class="lang-switcher relative">
  <button
    class="lang-btn flex items-center gap-1.5 px-2.5 py-1.5 text-xs font-heading font-semibold uppercase tracking-wider text-slate-300 hover:text-white rounded-lg hover:bg-white/10 transition-colors"
    aria-label="Change language"
  >
    <Icon name="lucide:globe" class="w-4 h-4" />
    <span>{currentLang.toUpperCase()}</span>
    <Icon name="lucide:chevron-down" class="w-3 h-3" />
  </button>

  <div
    class="lang-dropdown hidden absolute right-0 top-full mt-2 w-[14rem] bg-slate-900 border border-slate-700 rounded-xl shadow-xl overflow-hidden z-50"
  >
    {
      langEntries.map(([code, name]) => (
        <a
          href={getPathForLang(code)}
          class:list={[
            "block px-4 py-2.5 text-sm transition-colors",
            code === currentLang
              ? "bg-emerald-500/10 text-emerald-400 font-semibold"
              : "text-slate-300 hover:bg-white/5 hover:text-white",
          ]}
        >
          <span class="font-heading uppercase text-xs tracking-wider mr-2 opacity-50">
            {code}
          </span>
          {name}
        </a>
      ))
    }
  </div>
</div>

<script>
  document.querySelectorAll(".lang-switcher").forEach((switcher) => {
    const btn = switcher.querySelector(".lang-btn");
    const dropdown = switcher.querySelector(".lang-dropdown");

    btn?.addEventListener("click", (e) => {
      e.stopPropagation();
      // Close all other dropdowns first
      document.querySelectorAll(".lang-dropdown").forEach((d) => {
        if (d !== dropdown) d.classList.add("hidden");
      });
      dropdown?.classList.toggle("hidden");
    });
  });

  document.addEventListener("click", () => {
    document.querySelectorAll(".lang-dropdown").forEach((d) => {
      d.classList.add("hidden");
    });
  });
</script>
