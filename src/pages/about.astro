---
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

const lang = defaultLang;
const t = useTranslations(lang);

const features = [
  { title: t('about.features.squad.title'), desc: t('about.features.squad.desc') },
  { title: t('about.features.matches.title'), desc: t('about.features.matches.desc') },
  { title: t('about.features.training.title'), desc: t('about.features.training.desc') },
  { title: t('about.features.staff.title'), desc: t('about.features.staff.desc') },
  { title: t('about.features.leagues.title'), desc: t('about.features.leagues.desc') },
  { title: t('about.features.finances.title'), desc: t('about.features.finances.desc') },
  { title: t('about.features.news.title'), desc: t('about.features.news.desc') },
  { title: t('about.features.mod.title'), desc: t('about.features.mod.desc') },
];

const faqs = [
  { q: t('about.faq.download.q'), a: t('about.faq.download.a') },
  { q: t('about.faq.3d.q'), a: t('about.faq.3d.a') },
  { q: t('about.faq.ai.q'), a: t('about.faq.ai.a') },
  { q: t('about.faq.release.q'), a: t('about.faq.release.a') },
  { q: t('about.faq.platforms.q'), a: t('about.faq.platforms.a') },
  { q: t('about.faq.affiliated.q'), a: t('about.faq.affiliated.a') },
];
---

<BaseLayout title={`${t('about.badge')} — Openfoot Manager`} description={t('about.subtitle')} lang={lang}>
  <!-- Hero -->
  <section class="relative pt-32 pb-16 bg-gradient-to-b from-emerald-950 to-slate-950">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block px-4 py-1.5 text-xs font-heading font-bold uppercase tracking-widest text-emerald-400 bg-emerald-900/30 rounded-full mb-4">
          {t('about.badge')}
        </span>
        <h1 class="font-heading text-4xl md:text-6xl font-bold uppercase text-white mb-6">
          {t('about.heading.line1')}<br /><span class="text-amber-400">{t('about.heading.line2')}</span>
        </h1>
        <p class="text-lg text-emerald-100/70 leading-relaxed max-w-2xl">
          {t('about.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-20 bg-white dark:bg-slate-950">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto space-y-16">

        <!-- What is it -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('about.what.title')}
          </h2>
          <div class="space-y-4 text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
            <p set:html={t('about.what.p1')} />
            <p set:html={t('about.what.p2')} />
          </div>
        </div>

        <!-- Origin story -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('about.origin.title')}
          </h2>
          <div class="space-y-4 text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
            <p set:html={t('about.origin.p1')} />
            <p>{t('about.origin.p2')}</p>
          </div>
        </div>

        <!-- Features highlight -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('about.features.title')}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {features.map((item) => (
              <div class="p-5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
                <h3 class="font-heading text-lg font-bold uppercase text-slate-900 dark:text-white mb-1">
                  {item.title}
                </h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Tech -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('about.tech.title')}
          </h2>
          <div class="space-y-4 text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
            <p>{t('about.tech.intro')}</p>
            <ul class="space-y-2 pl-6 list-disc">
              <li set:html={t('about.tech.rust')} />
              <li set:html={t('about.tech.react')} />
              <li set:html={t('about.tech.tauri')} />
              <li set:html={t('about.tech.sqlite')} />
              <li set:html={t('about.tech.tailwind')} />
              <li set:html={t('about.tech.i18n')} />
            </ul>
          </div>
        </div>

        <!-- Contributing -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('about.contribute.title')}
          </h2>
          <div class="space-y-4 text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
            <p>{t('about.contribute.intro')}</p>
            <ul class="space-y-2 pl-6 list-disc">
              <li set:html={t('about.contribute.bugs')} />
              <li set:html={t('about.contribute.code')} />
              <li set:html={t('about.contribute.content')} />
              <li set:html={t('about.contribute.spread')} />
            </ul>
            <div class="flex flex-wrap gap-4 pt-4">
              <a
                href="https://github.com/openfootmanager/openfootmanager"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-white font-heading font-bold uppercase tracking-wider rounded-xl transition-all duration-200 shadow-lg shadow-emerald-500/25"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                {t('about.contribute.github')}
              </a>
              <a
                href="https://github.com/openfootmanager/openfootmanager/blob/develop/CONTRIBUTING.md"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 border-2 border-slate-300 dark:border-slate-700 hover:border-emerald-500 text-slate-700 dark:text-slate-300 font-heading font-bold uppercase tracking-wider rounded-xl transition-all duration-200"
              >
                {t('about.contribute.guide')}
              </a>
            </div>
          </div>
        </div>

        <!-- FAQ -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('about.faq.title')}
          </h2>
          <div class="space-y-4">
            {faqs.map((faq) => (
              <details class="group rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
                <summary class="flex items-center justify-between p-5 cursor-pointer font-heading font-bold text-lg uppercase text-slate-900 dark:text-white">
                  {faq.q}
                  <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 text-slate-600 dark:text-slate-400 leading-relaxed">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
