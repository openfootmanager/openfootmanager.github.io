---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages, defaultLang, type Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<BaseLayout title={`${t('about.badge')} — Openfoot Manager`} description={t('about.subtitle')} lang={lang}>
  <!-- Hero -->
  <section class="relative pt-32 pb-16 bg-gradient-to-b from-emerald-950 to-slate-950">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block px-4 py-1.5 text-xs font-heading font-bold uppercase tracking-widest text-emerald-400 bg-emerald-900/30 rounded-full mb-4">
          {t('about.badge')}
        </span>
        <h1 class="font-heading text-4xl md:text-6xl font-bold uppercase text-white mb-6">
          {t('about.heading.line1')}<br /><span class="text-amber-400">{t('about.heading.line2')}</span>
        </h1>
        <p class="text-lg text-emerald-100/70 leading-relaxed max-w-2xl">
          {t('about.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Placeholder content for translated about page -->
  <section class="py-20 bg-white dark:bg-slate-950">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto text-center py-12">
        <p class="text-lg text-slate-600 dark:text-slate-400">
          This page content is coming soon in your language.
        </p>
        <a href="/about" class="inline-flex items-center gap-2 mt-4 text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 transition-colors font-heading font-semibold uppercase tracking-wider">
          View in English
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
