---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturesPageContent from "../../components/FeaturesPageContent.astro";
import { languages, defaultLang, type Lang } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t("nav.features")} — Openfoot Manager`}
  description={t("features.subheading")}
  lang={lang}
>
  <FeaturesPageContent lang={lang} />
</BaseLayout>
