---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import DownloadSplitButton from '../../components/DownloadSplitButton';
import DownloadChecksums from '../../components/DownloadChecksums.astro';
import { languages, defaultLang, type Lang } from '../../i18n/ui';
import { useTranslations, formatReleaseDate } from '../../i18n/utils';
import { windowsDownloads, macosDownloads, linuxDownloads, releaseDate } from '../../data/downloads';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const requirements = [
  { label: t('download.requirements.os'), value: t('download.requirements.os.value') },
  { label: t('download.requirements.ram'), value: t('download.requirements.ram.value') },
  { label: t('download.requirements.disk'), value: t('download.requirements.disk.value') },
  { label: t('download.requirements.display'), value: t('download.requirements.display.value') },
];

const GITHUB_RELEASE_URL = 'https://github.com/openfootmanager/openfootmanager/releases/tag/v0.1.0';

const iconMonitor = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>';
const iconLaptop = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/></svg>';
const iconTerminal = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>';
---

<BaseLayout title={`${t('download.badge')} — Openfoot Manager`} description={t('download.subtitle')} lang={lang}>
  <!-- Hero -->
  <section class="relative pt-32 pb-4 bg-gradient-to-b from-emerald-950 to-slate-950">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block px-4 py-1.5 text-xs font-heading font-bold uppercase tracking-widest text-emerald-400 bg-emerald-900/30 rounded-full mb-4">
          {t('download.badge')}
        </span>
        <h1 class="font-heading text-4xl md:text-6xl font-bold uppercase text-white mb-6">
          {t('download.heading.line1')}<br /><span class="text-amber-400">{t('download.heading.line2')}</span>
        </h1>
        <p class="text-lg text-emerald-100/70 leading-relaxed max-w-2xl">
          {t('download.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-20 bg-white dark:bg-slate-950">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto space-y-16">

        <!-- Download buttons -->
        <div>
          <div class="flex items-center gap-3 mb-2">
            <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white">
              {t('download.version')}
            </h2>
          </div>
          <div class="flex items-center gap-3 mb-8">
            <span class="inline-block px-3 py-1 text-sm font-heading font-bold text-emerald-400 bg-emerald-900/30 rounded-full">
              {t('download.version.number')}
            </span>
            <span class="text-sm text-slate-500 dark:text-slate-400">{formatReleaseDate(releaseDate, lang)}</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
            <DownloadSplitButton
              client:load
              label={t('download.button.windows')}
              iconSvg={iconMonitor}
              options={windowsDownloads}
            />
            <DownloadSplitButton
              client:load
              label={t('download.button.macos')}
              iconSvg={iconLaptop}
              options={macosDownloads}
            />
            <DownloadSplitButton
              client:load
              label={t('download.button.linux')}
              iconSvg={iconTerminal}
              options={linuxDownloads}
            />
          </div>

          <div class="text-center">
            <a
              href="https://github.com/openfootmanager/openfootmanager/releases"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 transition-colors font-heading font-semibold uppercase tracking-wider"
            >
              <Icon name="lucide:github" class="w-4 h-4" />
              {t('download.button.allreleases')}
            </a>
          </div>
        </div>

                <!-- Alpha disclaimer -->
        <div class="rounded-2xl border-2 border-amber-400/50 bg-amber-50 dark:bg-amber-950/20 p-6 md:p-8">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-400/20 flex items-center justify-center">
              <Icon name="lucide:triangle-alert" class="w-5 h-5 text-amber-500" />
            </div>
            <div>
              <h2 class="font-heading text-xl font-bold uppercase text-amber-700 dark:text-amber-400 mb-3">
                {t('download.alpha.title')}
              </h2>
              <p class="text-slate-700 dark:text-slate-300 leading-relaxed mb-4" set:html={t('download.alpha.text')} />
              <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
                <li class="flex items-start gap-2">
                  <Icon name="lucide:alert-circle" class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" />
                  <span set:html={t('download.alpha.list.bugs')} />
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="lucide:alert-circle" class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" />
                  <span set:html={t('download.alpha.list.saves')} />
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="lucide:alert-circle" class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" />
                  <span set:html={t('download.alpha.list.features')} />
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="lucide:alert-circle" class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" />
                  <span set:html={t('download.alpha.list.feedback')} />
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- SHA-256 checksums -->
        <DownloadChecksums lang={lang} />

        <!-- System requirements -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('download.requirements.title')}
          </h2>
          <div class="rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
            {requirements.map((req, i) => (
              <div class:list={[
                'flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-0 p-4',
                i !== requirements.length - 1 && 'border-b border-slate-200 dark:border-slate-800',
              ]}>
                <div class="sm:w-1/3 font-heading font-bold text-sm uppercase tracking-wider text-slate-900 dark:text-white">
                  {req.label}
                </div>
                <div class="sm:w-2/3 text-sm text-slate-600 dark:text-slate-400">
                  {req.value}
                </div>
              </div>
            ))}
          </div>
          <p class="mt-4 text-sm text-slate-500 dark:text-slate-500 leading-relaxed">
            {t('download.requirements.note')}
          </p>
        </div>

        <!-- Installation instructions -->
        <div>
          <h2 class="font-heading text-3xl font-bold uppercase text-slate-900 dark:text-white mb-6">
            {t('download.instructions.title')}
          </h2>
          <div class="space-y-4 text-slate-700 dark:text-slate-300 leading-relaxed">
            <div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800">
              <Icon name="lucide:monitor" class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" />
              <p class="text-sm" set:html={t('download.instructions.windows')} />
            </div>
            <div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800">
              <Icon name="lucide:laptop" class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" />
              <p class="text-sm" set:html={t('download.instructions.macos')} />
            </div>
            <div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800">
              <Icon name="lucide:terminal" class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" />
              <p class="text-sm" set:html={t('download.instructions.linux')} />
            </div>
          </div>
        </div>

        <!-- Bug report CTA -->
        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 p-6 md:p-8 text-center">
          <Icon name="lucide:bug" class="w-10 h-10 text-emerald-500 mx-auto mb-4" />
          <h2 class="font-heading text-2xl font-bold uppercase text-slate-900 dark:text-white mb-3">
            {t('download.community.title')}
          </h2>
          <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-lg mx-auto">
            {t('download.community.text')}
          </p>
          <a
            href="https://github.com/openfootmanager/openfootmanager/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-white font-heading font-bold uppercase tracking-wider rounded-xl transition-all duration-200 shadow-lg shadow-emerald-500/25"
          >
            <Icon name="lucide:github" class="w-5 h-5" />
            {t('download.community.button')}
          </a>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
